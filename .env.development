# Local `pnpm --filter @workspace/hayyah-crm run dev`: use Vite proxy for /auth (same-origin, no CORS).
# Root `.env` may use absolute Keycloak URL for production builds; this file overrides in development only.
VITE_AUTH_TOKEN_URL=/auth/realms/hayyah/protocol/openid-connect/token

# Proxy /api/* to your backend (override if you run API locally, e.g. http://localhost:8080).
VITE_API_PROXY_TARGET=https://hayyah.me
