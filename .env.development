# Local dev: same-origin login via API proxy (Vite forwards /api → hayyah.me; server adds client_secret).
# Do not call Keycloak directly from the browser with VITE_CLIENT_SECRET.
VITE_AUTH_TOKEN_URL=/api/auth/token

# Proxy /api/* to your backend (override if you run API locally, e.g. http://localhost:8080).
VITE_API_PROXY_TARGET=https://hayyah.me

# Optional: `/welcome` store buttons (see root `.env.example`)
# VITE_IOS_APP_STORE_URL=
# VITE_PLAY_STORE_URL=
