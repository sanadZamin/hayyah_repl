KEYCLOAK_CLIENT_SECRET=your_client_secret_here
VITE_CLIENT_SECRET=your_client_secret_here

# API proxy (Vite dev): backend origin
# VITE_API_PROXY_TARGET=http://localhost:8080

# Optional: only the site origin for API (no /frontend). If set wrong, e.g. http://localhost:3000/frontend,
# requests become .../frontend/api/... and often 404. Leave unset in dev to use same-origin /api + Vite proxy.
# VITE_API_BASE_URL=https://hayyah.me

# API path after /api: omit for default /v1 (hayyah.me). Use empty for local Express `/api/*` only:
# VITE_API_PATH_PREFIX=

# Auth: in dev, prefer a relative path so Vite proxies /auth → Keycloak (see .env.development).
# Production builds often use the full token URL as a build arg instead.
# VITE_AUTH_TOKEN_URL=https://your-host/auth/realms/your-realm/protocol/openid-connect/token
# VITE_AUTH_PROXY_TARGET=https://your-host
